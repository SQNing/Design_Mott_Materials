prefix=/workspace/destdir
exec_prefix=${prefix}
includedir=/workspace/destdir/include
libdir=/workspace/destdir/lib

Name: CIF API library
Description: The CIF API CIF-parsing and manipulation library
URL: https://github.com/COMCIFS/cif_api/
Version: 0.4.2
Requires: icu-io
Requires.private:
Cflags: -I${includedir}
Libs: -L${libdir} -lcif
Libs.private:  -lsqlite3 -lm 

